<%- include(versionCheckTemplate, { version: '1.0.0'}) %>
let cc;

function hideGameLoadingOverlay () {
    const hide = window.__hideGameLoading;
    if (typeof hide === 'function') {
        hide();
        return;
    }

    const loading = document.getElementById('GameLoading');
    if (loading) {
        loading.classList.add('is-hidden');
    }
}

export class Application {
    constructor () {
        this.settingsPath = '<%= settingsJsonPath %>';
        this.showFPS = <%= showFPS %>;
    }

    init (engine) {
        cc = engine;
        cc.game.onPostBaseInitDelegate.add(this.onPostInitBase.bind(this));
        cc.game.onPostSubsystemInitDelegate.add(this.onPostSystemInit.bind(this));
    }

    onPostInitBase () {
        // Keep build-panel browser runs from using the web-mobile full-window fit.
        cc.settings.overrideSettings('screen', 'exactFitScreen', false);
    }

    onPostSystemInit () {
        // do custom logic
    }

    start () {
        return cc.game.init({
            debugMode: <%= debugMode %> ? cc.DebugMode.INFO : cc.DebugMode.ERROR,
            settingsPath: this.settingsPath,
            overrideSettings: {
                screen: {
                    exactFitScreen: false,
                },
                profiling: {
                    showFPS: this.showFPS,
                },
            },
        }).then(() => {
            if (cc.director && cc.Director && cc.Director.EVENT_AFTER_SCENE_LAUNCH) {
                cc.director.once(cc.Director.EVENT_AFTER_SCENE_LAUNCH, hideGameLoadingOverlay);
            }

            const result = cc.game.run();
            if (result && typeof result.then === 'function') {
                return result.then(() => {
                    hideGameLoadingOverlay();
                });
            }

            return result;
        });
    }
}
