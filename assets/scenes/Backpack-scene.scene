  {
    "__type__": "BackpackButtonTextInspectorEntry",
    "label": "背包",
    "title": "打开背包",
    "description": "重新打开背包界面，继续查看、拖动和整理道具。"
  },
  {
    "__type__": "BackpackButtonTextInspectorEntry",
    "label": "关闭",
    "title": "关闭背包",
    "description": "收起背包界面。物品位置、数量和当前分页会自动保存。"
  },
  {
    "__type__": "BackpackButtonTextInspectorEntry",
    "label": "堆叠",
    "title": "自动堆叠",
    "description": "选中一种道具后，自动搜索整个背包并合并所有同类道具，单组上限为 99。"
  },
  {
    "__type__": "BackpackButtonTextInspectorEntry",
    "label": "交换",
    "title": "交换模式",
    "description": "选中物品后点击，再点目标格交换；支持跨页。也可直接拖拽。"
  },
  {
    "__type__": "BackpackButtonTextInspectorEntry",
    "label": "合成",
    "title": "合成物品",
    "description": "选中可制作的成品后，自动从整个背包扣除配方材料并增加成品数量。"
  },
  {
    "__type__": "BackpackButtonTextInspectorEntry",
    "label": "整理{direction}",
    "title": "按稀有度整理",
    "description": "箭头表示本次方向：↑ 从普通到特殊，↓ 从特殊到普通。覆盖全部分页，并把空格移到最后。"
  },
  {
    "__type__": "BackpackButtonTextInspectorEntry",
    "label": "上一页",
    "title": "切换分页",
    "description": "切换到上一页背包。拖动物品经过此按钮时也会自动切页，用于跨页拖放。"
  },
  {
    "__type__": "BackpackButtonTextInspectorEntry",
    "label": "下一页",
    "title": "切换分页",
    "description": "切换到下一页背包。拖动物品经过此按钮时也会自动切页，用于跨页拖放。"
  },
